  "13525398": {
   "id": 13525398,
   "type": 653,
   "purposeId": 3,
   "iconPath": "0d24a8a42fafed20faf40db390ddc9dc642e36447287e938af35635149e7d3ac",
   "name": "《絨絨號》典藏版合集",
   "desc": "付梓印刷成單行本的《蒼天航路絨絨號》。可大幅提升<span style=\"display: inline-block; color: #f29e38ff; font-weight:bold;\">歡愉</span>角色的命途行跡。",
   "lore": "在單行本的腰封上印有很多推薦語，其中包括真珠、翡翠、砂金、托帕、拉帝奧、景元、飛霄、懷炎、爻光、華、卡芙卡、知更鳥、在田、施耐德、冥火大公、呼雷、隆介、花火、火花、開拓者等銀河知名人物。後來模糊老師因爲「捏造推薦語、虛假宣傳」賠了不少錢。<br /><br />「暗布雷拉律師，這些小肚雞腸的名人要合起夥來告我，我想聘請你爲我辯護，可以嗎？」<br />「哈哈哈，您真會說笑。我還沒活夠呢。」",
   "purpose": "行跡材料 <br />光錐晉階材料",
   "rarity": 4,
