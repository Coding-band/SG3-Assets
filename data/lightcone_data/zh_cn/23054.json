  "13525398": {
   "id": 13525398,
   "type": 653,
   "purposeId": 3,
   "iconPath": "0d24a8a42fafed20faf40db390ddc9dc642e36447287e938af35635149e7d3ac",
   "name": "《绒绒号》典藏版合集",
   "desc": "付梓印刷成单行本的《苍天航路绒绒号》。可大幅提升<span style=\"display: inline-block; color: #f29e38ff; font-weight:bold;\">欢愉</span>角色的命途行迹。",
   "lore": "在单行本的腰封上印有很多推荐语，其中包括真珠、翡翠、砂金、托帕、拉帝奥、景元、飞霄、怀炎、爻光、华、卡芙卡、知更鸟、在田、施耐德、冥火大公、呼雷、隆介、花火、火花、开拓者等银河知名人物。后来模糊老师因为「捏造推荐语、虚假宣传」赔了不少钱。<br /><br />「暗布雷拉律师，这些小肚鸡肠的名人要合起伙来告我，我想聘请你为我辩护，可以吗？」<br />「哈哈哈，您真会说笑。我还没活够呢。」",
   "purpose": "行迹材料 <br />光锥晋阶材料",
