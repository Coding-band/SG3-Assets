  "13618289": {
   "id": 13618289,
   "type": 653,
   "purposeId": 3,
   "iconPath": "adf3620e4f6d5da3565e25022f24e5eb9ca6fc333031e8a3e5bc88d03d81f98f",
   "name": "《绒绒号》手绘分镜稿",
   "desc": "正在分镜稿阶段的《苍天航路绒绒号》。可小幅提升<span style=\"display: inline-block; color: #f29e38ff; font-weight:bold;\">欢愉</span>角色的命途行迹。",
   "lore": "模糊老师作画的速度非常快，可以在一天时间内画完一个月的连载内容。但模糊老师从不这么做，对外宣称是为了保证质量，实际上很可能是懒得工作。<br /><br />「真奇怪，为什么市面上总是会出现很多一模一样的《绒绒号》原稿，而且每一张都明显是真迹？不会是模糊老师在用这招赚钱吧？」<br />「怎么可能？肯定是模糊老师精益求精，每一页都要画十遍，直到自己满意为止。」",
   "purpose": "行迹材料 <br />光锥晋阶材料",
   "rarity": 2,
   "rewardPath": "/material/13618289",
   "comeFrom": [
